---
import { categoryLabel } from "../data/categories";

const { post } = Astro.props;
const { data } = post;
const articleUrl = `${import.meta.env.BASE_URL}articles/${data.slug}/`;
---

<article class="story-card" data-category={data.category} data-keywords={`${data.title} ${data.excerpt} ${categoryLabel(data.category)}`}>
  <img src={`${import.meta.env.BASE_URL}${data.cover.replace(/^\//, "")}`} alt={data.coverAlt ?? data.title} />
  <div class="story-content">
    <span class="tag">{categoryLabel(data.category)}</span>
    <h3>{data.title}</h3>
    <p>{data.excerpt}</p>
    <a href={articleUrl}>閱讀文章</a>
  </div>
</article>
