---
const { story } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const imageSrc = story.cover.startsWith("/") ? `${baseUrl}${story.cover.replace(/^\//, "")}` : story.cover;
const articleUrl = story.href || "#";
---

<article
  class:list={["story-card", { "is-placeholder": story.placeholder }]}
  data-category={story.category}
  data-keywords={`${story.title} ${story.excerpt} ${story.categoryLabel}`}
>
  <img src={imageSrc} alt={story.coverAlt ?? story.title} />
  <div class="story-content">
    <span class="tag">{story.categoryLabel}</span>
    <h3>{story.title}</h3>
    <p>{story.excerpt}</p>
    <time datetime={story.dateIso}>{story.dateLabel}</time>
    <a href={articleUrl} aria-disabled={story.placeholder ? "true" : "false"}>
      {story.placeholder ? "Coming Soon" : "閱讀文章"}
    </a>
  </div>
</article>
