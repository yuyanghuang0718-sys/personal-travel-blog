---
const { src, alt = "", caption = "" } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const imageSrc = src?.startsWith("/")
  ? `${baseUrl}${src.replace(/^\//, "")}`
  : src;
---

<figure class="article-photo">
  <img src={imageSrc} alt={alt} />
  {caption && <figcaption>{caption}</figcaption>}
</figure>
